{
  "name": "@owdproject/module-atproto-jetstream",
  "version": "0.0.2",
  "license": "MIT",
  "homepage": "https://github.com/atproto-os/module-atproto-jetstream",
  "author": {
    "name": "Open Web Desktop Team",
    "url": "https://github.com/owdproject"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "development": "./src/module.ts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "nx": {
    "name": "module-atproto-jetstream"
  },
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "pnpm run dev:prepare && cd playground && pnpm exec nuxt dev",
    "dev:build": "nuxt build playground",
    "dev:generate": "NUXT_APP_BASE_URL=${NUXT_APP_BASE_URL:-/module-atproto-jetstream/} nuxt generate playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && cd playground && pnpm exec nuxt prepare",
    "validate": "desktop validate ."
  },
  "devDependencies": {
    "@nuxt/module-builder": "^1.0.2",
    "@owdproject/core": "workspace:*",
    "nuxt": "^4.4.4",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@owdproject/core": "3.4.0",
    "@owdproject/module-atproto": "^0.0.6"
  }
}
